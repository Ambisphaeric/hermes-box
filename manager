#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

die() { echo "error: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null || die "$1 is required"; }
valid_name() { [[ "$1" =~ ^[a-z0-9][a-z0-9_-]*$ ]]; }

requested_instance=""
if [[ "${1:-}" = "--instance" ]]; then
  [[ -n "${2:-}" ]] || die "--instance requires a name"
  requested_instance="$2"
  shift 2
fi

env_file_for() { echo ".instances/$1/instance.env"; }
active_name() {
  if [[ -n "$requested_instance" ]]; then
    echo "$requested_instance"
  elif [[ -L .env ]]; then
    basename "$(dirname "$(readlink .env)")"
  elif [[ -f .env ]]; then
    sed -n 's/^INSTANCE=//p' .env | tail -1
  fi
}
ENV_FILE=""
select_env() {
  local name; name="$(active_name)"
  if [[ -n "$requested_instance" ]]; then
    ENV_FILE="$(env_file_for "$name")"
  elif [[ -e .env || -L .env ]]; then
    ENV_FILE=.env
  else
    ENV_FILE="$(env_file_for "$name")"
  fi
  [[ -f "$ENV_FILE" ]] || die "instance is not initialized; run ./manager init light"
}
env_get() { sed -n "s/^$1=//p" "$ENV_FILE" | tail -1; }
instance() { env_get INSTANCE; }
compose() { docker compose --env-file "$ENV_FILE" "$@"; }

preset_values() {
  case "$1" in
    light) echo "2g 2 5901 6081 9119" ;;
    medium) echo "4g 4 5902 6082 9120" ;;
    high) echo "8g 6 5903 6083 9121" ;;
    *) die "preset must be light, medium, or high" ;;
  esac
}

cmd_init() {
  local preset="${1:-light}" name="${2:-hermes-$preset}" memory cpus vnc novnc dash vnc_password target
  valid_name "$name" || die "name must contain lowercase letters, digits, underscores, or hyphens"
  read -r memory cpus vnc novnc dash <<<"$(preset_values "$preset")"
  target="$(env_file_for "$name")"
  [[ ! -e "$target" ]] || die "$name already exists"
  mkdir -p ".instances/$name/data"
  cp .env.example "$target"
  vnc_password="$(openssl rand -hex 4)"
  sed -i.bak -e "s/^INSTANCE=.*/INSTANCE=$name/" -e "s/^MEMORY=.*/MEMORY=$memory/" \
    -e "s/^CPUS=.*/CPUS=$cpus/" -e "s/^VNC_PORT=.*/VNC_PORT=$vnc/" \
    -e "s/^NOVNC_PORT=.*/NOVNC_PORT=$novnc/" -e "s/^DASHBOARD_PORT=.*/DASHBOARD_PORT=$dash/" \
    -e "s/^HERMES_UID=.*/HERMES_UID=$(id -u)/" -e "s/^HERMES_GID=.*/HERMES_GID=$(id -g)/" \
    -e "s/^VNC_PASSWORD=.*/VNC_PASSWORD=$vnc_password/" "$target"
  rm "$target.bak"
  chmod 600 "$target" && chmod 700 ".instances/$name/data"
  ln -sfn "$target" .env
  echo "initialized and selected $name ($memory RAM); VNC password is in $target"
}

cmd_fleet_init() {
  [[ ! -e .env && ! -L .env ]] || die "an active .env already exists; initialize profiles individually"
  cmd_init light hermes-light
  rm .env
  cmd_init medium hermes-medium
  rm .env
  cmd_init high hermes-high
  echo "created three blank instances; hermes-high is selected"
}

cmd_use() {
  local name="${1:?usage: ./manager use NAME}" target
  target="$(env_file_for "$name")"
  [[ -f "$target" ]] || die "$name does not exist"
  rm -f .env
  ln -s "$target" .env
  echo "selected $name"
}

cmd_list() {
  local file name memory selected="$(active_name)" state
  printf '%-22s %-8s %-10s\n' INSTANCE MEMORY STATE
  for file in .instances/*/instance.env; do
    [[ -e "$file" ]] || continue
    name="$(sed -n 's/^INSTANCE=//p' "$file")"
    memory="$(sed -n 's/^MEMORY=//p' "$file")"
    if docker inspect "$name-hermes-1" >/dev/null 2>&1; then
      state="$(docker inspect -f '{{.State.Status}}' "$name-hermes-1")"
    else
      state=absent
    fi
    [[ "$name" = "$selected" ]] && name="*$name"
    printf '%-22s %-8s %-10s\n' "$name" "$memory" "$state"
  done
}

cmd_set() {
  [[ $# = 2 ]] || die "usage: ./manager set KEY VALUE"
  [[ "$1" =~ ^(MEMORY|CPUS|DISK_BUDGET_GB|VNC_PASSWORD|VNC_PORT|NOVNC_PORT|DASHBOARD_PORT|TZ|HERMES_UID|HERMES_GID)$ ]] || die "unsupported setting"
  grep -q "^$1=" "$ENV_FILE" || die "$1 is missing"
  [[ "$2" != *$'\n'* ]] || die "values cannot contain newlines"
  local escaped="${2//\\/\\\\}"; escaped="${escaped//&/\\&}"; escaped="${escaped//|/\\|}"
  sed -i.bak "s|^$1=.*|$1=$escaped|" "$ENV_FILE" && rm "$ENV_FILE.bak"
  echo "set $1 for $(instance); run up to apply"
}

cmd_clone() {
  local target="${1:?usage: ./manager clone NEW_NAME}" src target_env
  valid_name "$target" || die "invalid instance name"
  src="$(instance)"; target_env="$(env_file_for "$target")"
  [[ ! -e ".instances/$target" ]] || die "$target already exists"
  compose stop
  mkdir -p ".instances/$target"
  cp -a ".instances/$src/data" ".instances/$target/data"
  cp "$ENV_FILE" "$target_env"
  sed -i.bak "s/^INSTANCE=.*/INSTANCE=$target/" "$target_env" && rm "$target_env.bak"
  chmod 600 "$target_env"
  echo "cloned $src to $target; change its ports before running both"
}

cmd_reset() {
  local name="$(instance)"
  [[ "${1:-}" = "--yes" ]] || die "this deletes $name state; repeat with: ./manager reset --yes"
  compose down
  rm -rf ".instances/$name/data"
  mkdir -p ".instances/$name/data" && chmod 700 ".instances/$name/data"
  echo "blank state created for $name"
}

cmd_migrate_owner() {
  local uid="${1:?usage: ./manager migrate-owner UID GID}" gid="${2:?usage: ./manager migrate-owner UID GID}"
  [[ "$uid" =~ ^[0-9]+$ && "$gid" =~ ^[0-9]+$ ]] || die "UID and GID must be numeric"
  compose stop
  cmd_set HERMES_UID "$uid"
  cmd_set HERMES_GID "$gid"
  compose up -d --force-recreate
  echo "migrated $(instance) to host UID $uid and GID $gid"
}

cmd_watchdog_install() {
  local label plist
  label="org.hermes-box.$(instance)"
  plist="$HOME/Library/LaunchAgents/$label.plist"
  mkdir -p "$HOME/Library/LaunchAgents" .runtime
  sed -e "s|__LABEL__|$label|g" -e "s|__ROOT__|$ROOT|g" -e "s|__INSTANCE__|$(instance)|g" \
    -e "s|__PATH__|$PATH|g" .docs/launchd.plist.template > "$plist"
  launchctl bootout "gui/$(id -u)/$label" 2>/dev/null || true
  launchctl bootstrap "gui/$(id -u)" "$plist"
  echo "installed $plist"
}

main() {
  need docker
  case "${1:-help}" in
    init) shift; cmd_init "$@" ;;
    fleet-init) cmd_fleet_init ;;
    use) shift; cmd_use "$@" ;;
    list) cmd_list ;;
    help) sed -n '/^## Commands:/,$p' README.md | sed -n '1,36p' ;;
    *)
      select_env
      case "$1" in
        build) compose build --pull ;;
        up) compose up -d --build --remove-orphans ;;
        reconcile) compose up -d --no-build --remove-orphans ;;
        down) compose down ;;
        stop) compose stop ;;
        start) compose start ;;
        status) compose ps; docker stats --no-stream "$(instance)-hermes-1" 2>/dev/null || true ;;
        logs) compose logs -f --tail=200 ;;
        shell) compose exec hermes bash ;;
        setup) compose exec hermes bash -lc 'source /opt/hermes/.venv/bin/activate && hermes setup' ;;
        url) echo "http://127.0.0.1:$(env_get NOVNC_PORT)/vnc.html?autoconnect=1&resize=scale" ;;
        disk) du -sh ".instances/$(instance)/data"; echo "soft budget: $(env_get DISK_BUDGET_GB) GB" ;;
        set) shift; cmd_set "$@" ;;
        clone) shift; cmd_clone "$@" ;;
        reset) shift; cmd_reset "$@" ;;
        migrate-owner) shift; cmd_migrate_owner "$@" ;;
        watchdog-install) cmd_watchdog_install ;;
        watchdog-remove) label="org.hermes-box.$(instance)"; launchctl bootout "gui/$(id -u)/$label" 2>/dev/null || true; rm -f "$HOME/Library/LaunchAgents/$label.plist" ;;
        *) die "unknown command: $1" ;;
      esac ;;
  esac
}
main "$@"
